platform :ios, '12.0'

# Define a function to build Rust FFI library
def build_rust_ffi(app_target)
  # Get workspace root
  workspace_root = File.expand_path("../../..", __FILE__)
  flutter_root = "#{app_target.project.path}/../.."
  
  # Require Ruby build script
  script_path = "#{workspace_root}/build_ios_ffi.rb"
  
  # Run Rust compilation for iOS targets
  app_target.pre_build_phase do |phase|
    phase.shell_script = <<-SCRIPT
      # Build Rust FFI library for iOS
      cd "#{workspace_root}"
      
      # Determine iOS deployment target
      MIN_IOS_VERSION="12.0"
      ARCHS="${ARCHS}"
      
      echo "Building otter-mobile for iOS ($ARCHS)..."
      
      # Install Rust iOS targets if needed
      rustup target add aarch64-apple-ios aarch64-apple-ios-sim x86_64-apple-ios 2>/dev/null || true
      
      # Compile for different architectures
      if [[ "$ARCHS" == *"arm64"* ]]; then
        echo "Compiling for arm64 (device)..."
        cargo build -p otter-mobile --target aarch64-apple-ios --release
      fi
      
      if [[ "$ARCHS" == *"x86_64"* ]]; then
        echo "Compiling for x86_64 (simulator)..."
        cargo build -p otter-mobile --target x86_64-apple-ios --release
      fi
      
      # Create iOS simulator fat binary (arm64 + x86_64)
      if [[ "$PLATFORM_NAME" == "iphonesimulator" ]]; then
        echo "Creating simulator fat binary..."
        LIPO_INPUT=""
        [ -f target/aarch64-apple-ios-sim/release/libotter_mobile.a ] && LIPO_INPUT="$LIPO_INPUT target/aarch64-apple-ios-sim/release/libotter_mobile.a"
        [ -f target/x86_64-apple-ios/release/libotter_mobile.a ] && LIPO_INPUT="$LIPO_INPUT target/x86_64-apple-ios/release/libotter_mobile.a"
        
        if [ ! -z "$LIPO_INPUT" ]; then
          lipo $LIPO_INPUT -create -output target/otter_mobile_simulator.a
        fi
      fi
      
      # Copy .a file to Flutter framework location
      DERIVED_DATA_PATH="${HOME}/Library/Developer/Xcode/DerivedData"
      APP_FRAMEWORKS_PATH="${DERIVED_DATA_PATH}/*/Build/Products/*-iphoneos"
      
      # For now, copy to project directory
      mkdir -p "#{File.dirname(__FILE__)}/Frameworks"
      cp -v target/aarch64-apple-ios/release/libotter_mobile.a "#{File.dirname(__FILE__)}/Frameworks/" 2>/dev/null || true
      cp -v target/x86_64-apple-ios/release/libotter_mobile.a "#{File.dirname(__FILE__)}/Frameworks/" 2>/dev/null || true
    SCRIPT
  end
end

target 'Runner' do
  flutter_root = File.expand_path('..')
  load File.join(flutter_root, '.ios', 'Flutter', 'Flutter.podspec')
  
  pod 'Google-Mobile-Ads-SDK', '>= 10.0.0'

  post_install do |installer|
    installer.pods_project.targets.each do |target|
      flutter_additional_ios_build_settings(target)
      target.build_configurations.each do |config|
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
          '$(inherited)',
          'PERMISSION_LOCATION=1',
        ]
        
        # Enable finding native Rust library
        config.build_settings['LIBRARY_SEARCH_PATHS'] = [
          '$(LIBRARY_SEARCH_PATHS)',
          '$(PROJECT_DIR)/Frameworks',
        ]
        config.build_settings['HEADER_SEARCH_PATHS'] = [
          '$(HEADER_SEARCH_PATHS)',
          '$(PROJECT_DIR)/Frameworks',
        ]
      end
    end
  end
  
  # Build Rust FFI
  build_rust_ffi(target 'Runner')
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      # Link against Rust static library
      config.build_settings['OTHER_LDFLAGS'] ||= '$(inherited)'
      config.build_settings['OTHER_LDFLAGS'] += ' -lotter_mobile'
    end
  end
end
