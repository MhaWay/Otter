# Automatically generated by Android Studio (when first run).
# The file tells the Gradle build system where to find the Android SDK.

# Location of the SDK
sdk.dir=/home/user/Android/Sdk

# NDK version to use
ndk.version=25.2.9519653

# (Optional) Specify Android NDK path if Gradle can't find it
# android.ndkPath=/home/user/Android/Sdk/ndk/25.2.9519653

# (Optional) Set Rust toolchain override
# rust.dev.toolchain=stable
